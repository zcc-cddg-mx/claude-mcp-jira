# ================================
# CLAUDE API (VÍA PROXY INTERNO ZURICH)
# ================================

# Proxy LiteLLM interno — NO usar api.anthropic.com directamente
ANTHROPIC_BASE_URL=https://genai-lounge-nx-litellm-uat-emea.zurich.com
ANTHROPIC_AUTH_TOKEN=tu-proxy-token
ANTHROPIC_MODEL=eu.anthropic.claude-sonnet-4-6


# ================================
# JIRA CONFIG
# ================================

JIRA_URL=https://jira.zurich.com
JIRA_PAT=tu-personal-access-token
JIRA_PROJECT_KEY=PROJ
JIRA_TIMEOUT=10


# ================================
# NETWORK / SSL
# ================================

# Certificado raíz corporativo — requerido para jira.zurich.com
REQUESTS_CA_BUNDLE=/home/idavid/dev/claude/claude-mcp-jira/certs/zurichseguros-rootca-until-2031_03_20.crt


# ================================
# SERVICE LAYER
# ================================

# URL del service layer (http://service:8000 en Docker, http://localhost:8000 en dev)
SERVICE_URL=http://service:8000

# Usuario para audit log
JIRA_CLI_USER=tu-usuario

# Ruta del audit log — debe coincidir con el volumen en docker-compose.yml
AUDIT_LOG_PATH=/app/audit.log

# Rate limiting service layer (por usuario)
RATE_LIMIT_MAX_CALLS=30
RATE_LIMIT_WINDOW=60


# ================================
# MCP SERVER
# ================================

# API key interna requerida para conectarse al MCP server
MCP_API_KEY=clave-interna-segura

# CIDRs permitidos — solo hosts de la red Zurich
MCP_ALLOWED_CIDRS=10.0.0.0/8,192.168.0.0/16

# Mapeo API key → rol: "key1:lead,key2:dev" (dejar vacío para usar MCP_DEFAULT_ROLE)
# MCP_KEY_ROLES=

# Rol por defecto cuando no hay mapeo explícito
MCP_DEFAULT_ROLE=dev

# Rate limiting MCP (por API key — independiente del service layer)
MCP_RATE_LIMIT_MAX_CALLS=10
MCP_RATE_LIMIT_WINDOW=60

# Puerto y timeout del MCP server
MCP_PORT=8001
MCP_SERVICE_TIMEOUT=30

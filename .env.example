ANTHROPIC_API_KEY=sk-ant-...
JIRA_URL=https://jira.zurich.com
JIRA_PAT=tu-personal-access-token
JIRA_PROJECT_KEY=PROJ
# Ruta al certificado raíz corporativo
# REQUESTS_CA_BUNDLE=/home/idavid/dev/claude/claude-mcp-jira/certs/zurichseguros-rootca-until-2031_03_20.crt
# Usuario que aparece en el audit log
JIRA_CLI_USER=tu-usuario
# URL del service layer (cambiar si se despliega en servidor)
SERVICE_URL=http://localhost:8000
# Ruta del audit log (por defecto: audit.log en el directorio de trabajo)
# AUDIT_LOG_PATH=/var/log/claude-mcp-jira/audit.log

# --- MCP Server ---
# API key requerida para conectarse al MCP server (dejar vacío para deshabilitar en dev)
MCP_API_KEY=clave-interna-segura
# CIDRs permitidos (separados por coma) — dejar vacío para deshabilitar en dev
MCP_ALLOWED_CIDRS=10.0.0.0/8,192.168.0.0/16
# Mapeo API key → rol: "key1:lead,key2:dev" (opcional)
# MCP_KEY_ROLES=
# Rol por defecto cuando no hay mapeo
MCP_DEFAULT_ROLE=dev
# Rate limit del MCP server (independiente del service layer)
MCP_RATE_LIMIT_MAX_CALLS=10
MCP_RATE_LIMIT_WINDOW=60
# Puerto del MCP server
MCP_PORT=8001

# ================================
# CLAUDE API (VÍA PROXY INTERNO ZURICH)
# ================================

# Proxy LiteLLM interno — NO usar api.anthropic.com directamente
ANTHROPIC_BASE_URL=https://genai-lounge-nx-litellm-uat-emea.zurich.com
ANTHROPIC_AUTH_TOKEN=tu-proxy-token
ANTHROPIC_MODEL=eu.anthropic.claude-sonnet-4-6


# ================================
# JIRA CONFIG
# ================================

JIRA_URL=https://jira.zurich.com
JIRA_PAT=tu-personal-access-token

# Proyecto por defecto cuando no se especifica en el request
JIRA_DEFAULT_PROJECT=ZNRX

# Lista de proyectos permitidos (separados por coma) — valida inputs de usuario y Claude
JIRA_ALLOWED_PROJECTS=ZNRX,AIPROJECTS,SCRX

# Proyecto SAZ — endpoint dedicado POST /issues/saz
JIRA_SAZ_PROJECT_KEY=SAZ

JIRA_TIMEOUT=10

# Idioma del contenido generado para tickets (summary y description): "es" | "en"
# Usar "en" para proyectos internacionales (ej. AIPROJECTS). Default: "es"
TICKET_LANG=es

# Número máximo de resultados en búsquedas (hard cap: 50)
JIRA_MAX_RESULTS=50


# ================================
# NETWORK / SSL
# ================================

# En Docker: el Dockerfile copia los certs a /etc/ssl/certs/ y crea el alias zurich-root-ca.crt
REQUESTS_CA_BUNDLE=/etc/ssl/certs/zurich-root-ca.crt

# En desarrollo local (fuera de Docker), usar la ruta al archivo original:
# REQUESTS_CA_BUNDLE=/ruta/al/repo/certs/zurichseguros-rootca-until-2031_03_20.crt

# Para llamadas a api-zurich.data-fact.com (SSL inspection via ssldecrypt.latam.zurich.com):
# REQUESTS_CA_BUNDLE=/etc/ssl/certs/zurich-ssl-ca.pem


# ================================
# APP
# ================================

# Entorno de ejecución: "dev" habilita /docs y /redoc; "prod" los deshabilita
APP_ENV=dev

# Ruta de la base de datos SQLite de proyectos
# En Docker usar /app/projects.db (persistir con volumen); en dev puede ser relativa
PROJECT_DB_PATH=projects.db


# ================================
# SERVICE LAYER
# ================================

# URL del service layer (http://service:8000 en Docker, http://localhost:8000 en dev)
SERVICE_URL=http://service:8000

# Usuario para audit log
JIRA_CLI_USER=tu-usuario

# Ruta del audit log — debe coincidir con el volumen en docker-compose.yml
AUDIT_LOG_PATH=/app/audit.log

# Rate limiting service layer (por usuario)
RATE_LIMIT_MAX_CALLS=30
RATE_LIMIT_WINDOW=60


# ================================
# MCP SERVER
# ================================

# API key interna requerida para conectarse al MCP server
MCP_API_KEY=clave-interna-segura

# CIDRs permitidos — solo hosts de la red Zurich
MCP_ALLOWED_CIDRS=10.0.0.0/8,192.168.0.0/16

# Mapeo API key → rol: "key1:lead,key2:dev" (dejar vacío para usar MCP_DEFAULT_ROLE)
# MCP_KEY_ROLES=

# Rol por defecto cuando no hay mapeo explícito
MCP_DEFAULT_ROLE=dev

# Rate limiting MCP (por API key — independiente del service layer)
MCP_RATE_LIMIT_MAX_CALLS=10
MCP_RATE_LIMIT_WINDOW=60

# Puerto y timeout del MCP server
MCP_PORT=8001
MCP_SERVICE_TIMEOUT=30

# Tamaño máximo de payload en el MCP server (caracteres)
MCP_MAX_PAYLOAD_SIZE=4096


# ================================
# GIT INTELLIGENCE (Fase 9)
# ================================

# Brecha en minutos entre commits para considerar una nueva sesión de trabajo
GIT_SESSION_GAP_MINUTES=120

# Duración mínima de una sesión para registrar worklog (minutos)
GIT_MIN_SESSION_MINUTES=15

# Duración máxima de una sesión (cap en minutos)
GIT_MAX_SESSION_MINUTES=240

# Umbral de líneas cambiadas para añadir margen de tiempo adicional (LOC nudge)
GIT_LOC_NUDGE_THRESHOLD=200


# ================================
# FASE 5 — OBSERVABILIDAD (futura / opcional)
# ================================

# Reintentos para llamadas a Jira (no implementado aún)
# JIRA_RETRY_ATTEMPTS=3

# Circuit breaker — umbral de fallos y timeout (no implementado aún)
# MCP_CB_FAILURE_THRESHOLD=5
# MCP_CB_TIMEOUT=60

# Trazado de requests (no implementado aún)
# ENABLE_REQUEST_TRACING=true
